# Exemple pour `docker compose -f docker-compose.prod.yml` (copier vers `.env` dans ce répertoire).
# Ne pas committer de secrets.

PILOX_DOMAIN=pilox.example.com
AUTH_URL=https://pilox.example.com
POSTGRES_PASSWORD=
REDIS_PASSWORD=
AUTH_SECRET=
ENCRYPTION_KEY=
ACME_EMAIL=ops@example.com

# Optionnel mais recommandé : jeton pour l'assistant https://<PILOX_DOMAIN>/setup (≥ 32 caractères)
# PILOX_SETUP_TOKEN=

# Désactiver les migrations au démarrage du conteneur pilox-app (défaut : migrations auto si DATABASE_URL)
# PILOX_SKIP_MIGRATE=1

# Rebuild de l’index marketplace (Postgres) après les migrations — désactiver sur les réplicas secondaires
# PILOX_SKIP_MARKETPLACE_INDEX=1

# Catalogue marketplace : db (défaut compose) lit marketplace_catalog_rows ; redis / autre selon app/.env.example
# MARKETPLACE_CATALOG_SOURCE=db

# Durcissement prod — voir docs/PRODUCTION.md (sections 4.1–4.2)
# PILOX_CLIENT_IP_SOURCE=real_ip
# Hôtes internes autorisés pour les fetch serveur (import, webhooks mesh/budget, workflows HTTP, marketplace) : noms ou *.suffix, séparés par des virgules
# PILOX_EGRESS_FETCH_HOST_ALLOWLIST=registry.internal.example,hooks.internal.example
# PILOX_EGRESS_FETCH_MAX_REDIRECTS=5
# Nœuds « code » workflow : désactivés par défaut en prod (NODE_ENV dans l’image). Décommenter false pour les activer (confiance requise).
# PILOX_WORKFLOW_DISABLE_CODE_NODE=false
# Worker mesh WAN (optionnel) — webhook soumis au même garde-fou egress
# MESH_WAN_REDIS_WORKER_MODE=log
# MESH_WAN_REDIS_WORKER_WEBHOOK_URL=
# MESH_WAN_REDIS_WORKER_WEBHOOK_BEARER=

# Avertissement déploiement si l’entrée catalogue n’a pas de métadonnées pricing (voir app/.env.example)
# MARKETPLACE_PRICING_ENFORCEMENT=warn

# Marketplace self-registration — point all instances at the same Pilox market-place service (port 4077 typical)
# PILOX_MARKETPLACE_URL=https://marketplace.example.com   # overrides hub default
# PILOX_MARKETPLACE_HUB_URL=https://marketplace.example.com  # fleet default when PILOX_MARKETPLACE_URL unset
# If the image is built with NEXT_PUBLIC_PILOX_LANDING_URL=https://pilox-public.web.app, that same URL is used as last fallback for node registration when the two vars above are empty (host must expose /v1/nodes/*).
# PILOX_MARKETPLACE_NODE_SECRET=   # optional if hub has MARKETPLACE_OPEN_NODE_REGISTRATION=true
# PILOX_MARKETPLACE_NODE_STATE_FILE=/data/pilox/marketplace-node.json  # persisted open-registration token (compose volume)
# PILOX_MARKETPLACE_DISABLE_OPEN_REGISTER=true  # force shared secret only
# PILOX_NODE_NAME=my-pilox-node
# PILOX_NODE_REGION=eu-west

# Profil `observability` (Tempo + Prometheus + OTel Collector — pas de Grafana) — optionnel
# docker compose --profile observability up -d
# Pilox doit envoyer les traces vers le collecteur :
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# UI native /observability (admin), côté serveur :
# PROMETHEUS_OBSERVABILITY_URL=http://prometheus:9090
# TEMPO_OBSERVABILITY_URL=http://tempo:3200
