{
  "name": "pilox",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build:a2a-sdk": "npm run build --prefix ../packages/a2a-sdk",
    "dev": "next dev",
    "build": "next build",
    "postbuild": "node scripts/fix-standalone-client-manifests.mjs",
    "start": "next start",
    "start:standalone": "node .next/standalone/server.js",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:migrate:run": "npx tsx src/db/migrate.ts",
    "db:seed": "npx tsx src/db/seed.ts",
    "test": "vitest run",
    "test:marketplace-api": "vitest run src/app/api/marketplace src/lib/marketplace/transparency-paths.test.ts src/lib/marketplace/registry-record-proof.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "mesh:infra": "docker compose up -d postgres redis",
    "mesh:otel": "docker compose --profile otel up -d",
    "check:otel-routes": "node scripts/check-api-routes-otel.cjs",
    "docs:validate-openapi-schemas": "node scripts/validate-planetary-docs.cjs",
    "docs:validate-planetary": "npm run docs:validate-openapi-schemas",
    "smoke:planetary": "node ../scripts/planetary-smoke.mjs",
    "mesh:wan-worker": "npx tsx scripts/mesh-wan-redis-worker.ts",
    "marketplace:index-sync": "npx tsx scripts/marketplace-index-sync.ts",
    "dataset:emit-gold": "node scripts/emit-hive-copilot-gold.mjs",
    "dataset:hive-copilot": "node scripts/generate-hive-copilot-dataset.mjs",
    "dataset:hive-copilot:release": "node scripts/generate-hive-copilot-dataset.mjs --variants 10 --pipeline-pairs 400",
    "dataset:merge-train": "node scripts/merge-hive-copilot-train.mjs",
    "dataset:render-blocks-rag": "node scripts/render-hive-blocks-rag.mjs",
    "dataset:download-hf": "python scripts/download-public-datasets.py",
    "dataset:download-n8n-community": "python scripts/download-n8n-community-workflows.py --max 450",
    "dataset:extract-n8n-templates": "node scripts/extract-n8n-templates.mjs",
    "dataset:check-blocks": "node scripts/check-hive-blocks-drift.mjs",
    "dataset:convert-public": "python scripts/convert_hf_public_to_hive.py",
    "dataset:eval-golden": "node scripts/eval-golden-copilot.mjs",
    "dataset:eval-quality": "node scripts/eval-copilot-quality.mjs",
    "dataset:snapshot": "node scripts/snapshot-hive-copilot-dataset.mjs",
    "dataset:prepare-train": "npm run dataset:render-blocks-rag && npm run dataset:convert-public && npm run dataset:merge-train && npm run dataset:eval-golden && npm run dataset:check-blocks",
    "dataset:full-pipeline": "npm run dataset:download-hf && npm run dataset:render-blocks-rag && npm run dataset:emit-gold && npm run dataset:hive-copilot:release && npm run dataset:convert-public && npm run dataset:merge-train && npm run dataset:eval-golden && npm run dataset:eval-quality && npm run dataset:check-blocks && npm run dataset:audit",
    "dataset:model-release-prep": "npm run dataset:eval-golden && npm run dataset:eval-quality && npm run dataset:snapshot",
    "dataset:audit": "node scripts/audit-hive-copilot-dataset.mjs",
    "dataset:train-lora": "python ../datasets/hive-copilot-v1/training/train_lora.py",
    "dataset:train-lora:smoke": "python ../datasets/hive-copilot-v1/training/train_lora.py --preset smoke --output ../datasets/hive-copilot-v1/training/outputs/smoke-test",
    "dataset:train-lora:dev": "python ../datasets/hive-copilot-v1/training/train_lora.py --preset dev --output ../datasets/hive-copilot-v1/training/outputs/lora-dev",
    "dataset:train-lora:production": "python ../datasets/hive-copilot-v1/training/train_lora.py --preset production --output ../datasets/hive-copilot-v1/training/outputs/lora-production",
    "dataset:train-lora:modal": "python -m modal run ../datasets/hive-copilot-v1/training/modal_lora_train.py",
    "dataset:fetch-modal-lora": "python -m modal volume get hive-copilot-lora-output lora-hive-copilot ./models/hive-copilot-lora",
    "dataset:golden-inference": "python ../datasets/hive-copilot-v1/training/run_golden_inference_lora.py",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "load:smoke": "node scripts/load-smoke.mjs",
    "e2e:prepare-mfa": "npx tsx scripts/e2e-prepare-mfa.ts"
  },
  "dependencies": {
    "@base-ui/react": "1.3.0",
    "@noble/curves": "^1.9.7",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-async-hooks": "^2.6.0",
    "@opentelemetry/core": "^2.6.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-metrics": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@pilox/a2a-sdk": "file:../packages/a2a-sdk",
    "@pilox/buyer-config": "file:../packages/pilox-buyer-config",
    "@tailwindcss/postcss": "^4.0.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/dockerode": "^4.0.1",
    "@types/ioredis": "^4.28.10",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@xyflow/react": "^12.10.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dockerode": "^4.0.9",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^12.38.0",
    "ioredis": "^5.10.1",
    "lucide-react": "^0.577.0",
    "nanoid": "^5.1.7",
    "next": "^15.5.14",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.8",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^2.15.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "stripe": "^17.7.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.0.7",
    "tsx": "^4.19.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@playwright/test": "^1.50.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/expect": "^3.2.4",
    "@vitest/runner": "^3.2.4",
    "@vitest/snapshot": "^3.2.4",
    "@vitest/spy": "^3.2.4",
    "@vitest/utils": "^3.2.4",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "browserslist": "^4.28.1",
    "caniuse-lite": "1.0.30001579",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "^15.5.14",
    "otplib": "^12.0.1",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "caniuse-lite": "1.0.30001579"
  }
}
