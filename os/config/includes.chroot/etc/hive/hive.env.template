# Hive OS Environment Configuration
# This file is generated from hive.env.template on first boot.
# Secrets are auto-generated. Do not commit this file.

NODE_ENV=production
PORT=3000

# Database
DATABASE_URL=postgresql://hive:HIVE_DB_PASSWORD@localhost:5432/hive

# Public URL of this Hive instance (required). Used for auth + CORS.
# On Hive OS, first-boot sets a default based on the current IP; change it if you add DNS/TLS.
AUTH_URL=https://HIVE_AUTH_HOST

# Redis
REDIS_PASSWORD=HIVE_REDIS_PASSWORD
REDIS_URL=redis://:HIVE_REDIS_PASSWORD@localhost:6379

# Marketplace list API: db uses Postgres index (rebuilt after migrations / container start)
MARKETPLACE_CATALOG_SOURCE=db

# Optional transparency: unauthenticated GET /api/marketplace/<handle>/verify (IP rate limit). In-app docs: /docs/marketplace-transparency
# HIVE_MARKETPLACE_VERIFY_PUBLIC=true
# Browser origins allowed for CORS on verify + catalog-export (comma-separated), in addition to AUTH_URL origin
# HIVE_MARKETPLACE_CORS_ORIGINS=https://your-project.web.app

# Authentication secret (auto-generated)
AUTH_SECRET=HIVE_AUTH_SECRET

# Encryption key (auto-generated) — exactly 64 hex characters (32 bytes)
ENCRYPTION_KEY=HIVE_ENCRYPTION_KEY

# API token for CLI and external access (auto-generated)
HIVE_API_TOKEN=HIVE_API_TOKEN_VALUE

# Docker socket path
DOCKER_HOST=unix:///var/run/docker.sock

# Firecracker microVM configuration
FC_KERNEL_PATH=/var/lib/hive/firecracker/kernels/vmlinux
FC_BASE_ROOTFS=/var/lib/hive/firecracker/rootfs/base-rootfs.ext4
FC_BASE_DIR=/var/lib/hive/firecracker
FC_BRIDGE=hive-br0
FC_JAILER_UID=1500
FC_JAILER_GID=1500

# GPU inference service (auto-detected at first boot)
# Shared host service (vLLM/Ollama) — agents access via vsock, never direct GPU
GPU_AVAILABLE=false
INFERENCE_BACKEND=ollama
INFERENCE_PORT=11434
INFERENCE_VSOCK_PORT=11434

# Internal token for auto-resume and service-to-service calls (auto-generated)
HIVE_INTERNAL_TOKEN=HIVE_INTERNAL_TOKEN_VALUE

# Agent sleeping — auto-pause idle agents
AUTO_SLEEP_ENABLED=true
AUTO_SLEEP_IDLE_SECONDS=300

# Logging
LOG_LEVEL=info

# Workflow JS code nodes: default off when NODE_ENV=production (no variable needed). To allow: HIVE_WORKFLOW_DISABLE_CODE_NODE=false
# Private URL fetches (import, webhooks, workflow HTTP): set HIVE_EGRESS_FETCH_HOST_ALLOWLIST if you use internal hostnames (see docs/PRODUCTION.md section 4.2).
